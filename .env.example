# =============================================================
# AgenticOS Root Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ── Agent Provider API ──────────────────────────────────────
AGENT_API_HOST=0.0.0.0
AGENT_API_PORT=8000

# ── LM Studio ───────────────────────────────────────────────
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TIMEOUT=120

# ── LM Studio Model Aliases ─────────────────────────────────
# These are the short names you pass as "model" in API calls
LLM_DEFAULT_MODEL=nemotron
LLM_MODEL_NEMOTRON=nvidia/nemotron-3-nano-4b
LLM_MODEL_GEMMA=google/gemma-3n-e4b

# ── MySQL (shared by agent API logging & web app) ────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Qaz123#
DB_NAME=agenticos

# ── Web App ─────────────────────────────────────────────────
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=5000

# ── Agent Provider URL (used by web app) ────────────────────
AGENT_PROVIDER_URL=http://127.0.0.1:8000

# ── Observability ───────────────────────────────────────────
ENABLE_TRACES=true
TRACE_SAMPLING_RATE=0.1
METRICS_INTERVAL=60

# ── Security ────────────────────────────────────────────────
RATE_LIMIT=1000
AUTH_TOKEN_EXPIRY=3600
DEBUG=false

